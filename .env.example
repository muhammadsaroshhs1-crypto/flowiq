# PostgreSQL connection string for Prisma.
DATABASE_URL=

# Clerk browser publishable key.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Clerk server-side secret key.
CLERK_SECRET_KEY=

# Clerk webhook signing secret from the Clerk dashboard.
CLERK_WEBHOOK_SECRET=

# Clerk route configuration.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# OpenAI API key for intelligence suggestions and draft generation.
OPENAI_API_KEY=

# Redis connection string for BullMQ workers.
REDIS_URL=

# AES secret used to encrypt integration credentials.
INTEGRATION_SECRET=

# Public application URL used by webhooks and callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000
